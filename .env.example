# ============================================
# Frontend (Vite) — variables de entorno
# ============================================
# Copia este archivo a `.env` (o `.env.local`) y ajusta los valores.
# Solo las variables con prefijo VITE_ quedan expuestas al cliente.

# Base URL del backend REST. Debe incluir el prefijo /api/v1.
# Si se omite, el cliente usa http://localhost:3001/api/v1 por defecto.
VITE_API_URL=http://localhost:3001/api/v1
