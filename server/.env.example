# ============================================================================
# Plataforma TEC — Backend (.env.example)
# Copia este archivo a `.env` y completa los valores reales.
# NUNCA subas `.env` al repo (ya está en .gitignore).
# ============================================================================

# --- Servidor HTTP ---
PORT=3001
NODE_ENV=development

# Orígenes permitidos por CORS (coma-separados). El frontend Vite usa 5173.
CORS_ORIGINS=http://localhost:5173

# --- Base de datos (MariaDB/MySQL) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=plataforma
DB_CONNECTION_LIMIT=10

# --- Autenticación JWT (preparado, aún no obligatorio en rutas) ---
# REQUISITO: Mínimo 32 caracteres, debe incluir números y/o caracteres especiales
# Generar uno fuerte: `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
JWT_SECRET=change-me-please-with-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=8h
