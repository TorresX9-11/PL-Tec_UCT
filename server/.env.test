# ============================================================================
# Plataforma TEC — Variables de entorno para testing
# ============================================================================

NODE_ENV=test
PORT=3001

CORS_ORIGINS=http://localhost:5173

# Base de datos de prueba
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=plataforma_test
DB_CONNECTION_LIMIT=10

# JWT válido para tests (mínimo 32 chars, con números y caracteres especiales)
JWT_SECRET=test-secret-key-32-chars-long!1234567890
JWT_EXPIRES_IN=1h
